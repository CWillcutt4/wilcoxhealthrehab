DATABASE_URL="file:./dev.db"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-in-production"

# Owner email — receives copies of signed waivers
OWNER_EMAIL="owner@wilcoxhealthrehab.com"

# Resend (https://resend.com) — leave blank in dev to console-log emails
RESEND_API_KEY=""
EMAIL_FROM="Wilcox Health and Rehab Center <noreply@wilcoxhealthrehab.com>"

# Shopify — leave blank in dev; checkout will be simulated
SHOPIFY_STORE_DOMAIN=""
SHOPIFY_ADMIN_API_TOKEN=""
SHOPIFY_STOREFRONT_TOKEN=""
SHOPIFY_WEBHOOK_SECRET=""

# Viztin — leave blank; if unset, staff gets emailed to issue the key manually
VIZTIN_API_URL=""
VIZTIN_API_TOKEN=""

# Cron secret — used to protect /api/cron endpoints
CRON_SECRET="change-me"
